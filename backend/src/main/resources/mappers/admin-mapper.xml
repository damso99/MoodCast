<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "https://mybatis.org/dtd/mybatis-3-mapper.dtd">

<!--
  관리자 페이지용 MyBatis mapper입니다.

  초보자 기준 설명:
  - AdminDao 인터페이스에 있는 메서드와 실제 SQL을 연결합니다.
  - 아래 select id="selectTotalMemberCount"는 AdminDao.selectTotalMemberCount()와 연결됩니다.
-->
<mapper namespace="com.moodcast.admin.dao.AdminDao">

    <!--
      대시보드 요약 조회 결과를 AdminDashboardSummary VO에 연결합니다.
    -->
    <resultMap id="adminDashboardSummaryMap" type="com.moodcast.admin.vo.AdminDashboardSummary">
        <result property="totalMemberCount" column="total_member_count"/>
        <result property="todayNewMemberCount" column="today_new_member_count"/>
        <result property="postCount" column="post_count"/>
    </resultMap>

    <!--
      회원 목록 조회 결과를 AdminMember VO에 연결합니다.

      DB 컬럼명은 member_id처럼 snake_case이고,
      Java 필드명은 memberId처럼 camelCase라서 resultMap으로 직접 연결합니다.
    -->
    <resultMap id="adminMemberMap" type="com.moodcast.admin.vo.AdminMember">
        <id property="memberId" column="member_id"/>
        <result property="name" column="name"/>
        <result property="nickname" column="nickname"/>
        <result property="email" column="email"/>
        <result property="status" column="status"/>
        <result property="createdAt" column="created_at"/>
        <result property="role" column="role"/>
        <result property="lastLoginAt" column="last_login_at"/>
        <result property="reportCount" column="report_count"/>
        <result property="postCount" column="post_count"/>
        <result property="commentCount" column="comment_count"/>
    </resultMap>

    <!--
      관리자 개인 정보 조회 결과를 AdminProfile VO에 연결합니다.
    -->
    <resultMap id="adminProfileMap" type="com.moodcast.admin.vo.AdminProfile">
        <id property="memberId" column="member_id"/>
        <result property="name" column="name"/>
        <result property="nickname" column="nickname"/>
        <result property="phone" column="phone"/>
        <result property="profileImageUrl" column="profile_image_url"/>
    </resultMap>

    <!--
      전체 회원 수 조회입니다.

      members 테이블에 있는 모든 회원 수를 조회합니다.

      지금 기준:
      - 삭제 여부, 상태 여부를 따로 거르지 않습니다.
      - 사용자가 직접 테스트한 SELECT COUNT(*) FROM members 기준과 동일합니다.
    -->
    <select id="selectTotalMemberCount" resultType="long">
        select count(*)
        from members
    </select>

    <!--
      전체 회원 목록 조회입니다.

      사용자 관리 페이지의 현재 선택 탭이 "전체"일 때 테이블에 출력할 데이터를 조회합니다.
      지금은 모든 회원을 보여주는 단계이므로 deleted_at, status, role 조건을 걸지 않습니다.
    -->
    <select id="selectMembers" resultMap="adminMemberMap">
        select
            member_id,
            name,
            nickname,
            email,
            status,
            created_at,
            role,
            last_login_at,
            0 as report_count,
            (select count(*)
             from post_tbl p
             where p.member_id = members.member_id
               and p.deleted_yn = 'N') as post_count,
            (select count(*)
             from comment_tbl c
             where c.member_id = members.member_id
               and c.deleted_yn = 'N') as comment_count
        from members
        order by created_at desc
    </select>

    <!--
      관리자 추가 페이지의 회원 검색입니다.

      searchType 값에 따라 검색 대상 컬럼을 바꿉니다.
      - email: 이메일 검색
      - name: 실명 검색

      limit 20을 둔 이유:
      - 검색어가 짧을 때 너무 많은 회원이 한 번에 화면에 나오지 않도록 제한합니다.
    -->
    <select id="searchMembersForAdminPromotion" resultMap="adminMemberMap">
        select
            member_id,
            name,
            nickname,
            email,
            status,
            created_at,
            role,
            last_login_at,
            0 as report_count,
            (select count(*)
             from post_tbl p
             where p.member_id = members.member_id
               and p.deleted_yn = 'N') as post_count,
            (select count(*)
             from comment_tbl c
             where c.member_id = members.member_id
               and c.deleted_yn = 'N') as comment_count
        from members
        where status = 'ACTIVE'
          and role in ('USER', 'MEMBER')
          and (
            <choose>
                <when test="searchType == 'name'">
                    name like concat('%', #{keyword}, '%')
                </when>
                <when test="searchType == 'nickname'">
                    nickname like concat('%', #{keyword}, '%')
                </when>
                <otherwise>
                    email like concat('%', #{keyword}, '%')
                </otherwise>
            </choose>
          )
        order by created_at desc
        limit 20
    </select>

    <!--
      관리자 추가 페이지에서 선택한 회원의 role을 관리자 등급으로 변경합니다.

      조건을 엄격하게 둔 이유:
      - ACTIVE 상태가 아닌 회원은 승급 대상이 아닙니다.
      - 이미 관리자인 회원을 다시 승급하지 않도록 일반 회원 role만 허용합니다.
    -->
    <update id="updateMemberRoleForAdminPromotion">
        update members
        set role = #{role},
            updated_at = CONVERT_TZ(NOW(6), '+00:00', '+09:00')
        where member_id = #{memberId}
          and status = 'ACTIVE'
          and role in ('USER', 'MEMBER')
    </update>

    <!--
      관리자 대시보드 요약 조회입니다.

      total_member_count:
      - members 테이블 전체 회원 수입니다.

      today_new_member_count:
      - 오늘 00:00:00부터 현재까지 가입한 회원 수입니다.
      - created_at 기준으로 계산합니다.

      post_count:
      - 삭제되지 않은 게시글 수입니다.
      - 기존 검색 기능에서 post_tbl.deleted_yn = 'N' 기준을 사용하고 있어 동일하게 맞췄습니다.
    -->
    <select id="selectDashboardSummary" resultMap="adminDashboardSummaryMap">
        select
            (select count(*)
             from members) as total_member_count,
            (select count(*)
             from members
             where created_at >= curdate()
               and created_at &lt; date_add(curdate(), interval 1 day)) as today_new_member_count,
            (select count(*)
             from post_tbl
             where deleted_yn = 'N') as post_count
    </select>

    <!--
      로그인한 관리자 본인의 개인 정보를 조회합니다.
    -->
    <select id="selectAdminProfile" resultMap="adminProfileMap">
        select
            member_id,
            name,
            nickname,
            phone,
            profile_image_url
        from members
        where member_id = #{memberId}
        limit 1
    </select>

    <!--
      로그인한 관리자 본인의 실명, 닉네임, 전화번호를 수정합니다.
    -->
    <update id="updateAdminProfile">
        update members
        set name = #{name},
            nickname = #{nickname},
            phone = #{phone},
            updated_at = CONVERT_TZ(NOW(6), '+00:00', '+09:00')
        where member_id = #{memberId}
    </update>
</mapper>
